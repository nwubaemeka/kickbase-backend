# ── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── JWT Auth ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=7d

# ── Blockchain ───────────────────────────────────────
# Base Sepolia Testnet
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# Your OPERATOR wallet private key (the one you used as _owner in the contract)
# NEVER commit this key. Keep it secret.
OPERATOR_PRIVATE_KEY=0xYOUR_OPERATOR_WALLET_PRIVATE_KEY

# Deployed contract address (from Remix after deployment)
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# ── Database ─────────────────────────────────────────
DB_PATH=./kickbase.db

# ── For mainnet later: swap these values ─────────────
# RPC_URL=https://mainnet.base.org
# CHAIN_ID=8453
# EXPLORER_URL=https://basescan.org
EXPLORER_URL=https://sepolia.basescan.org
